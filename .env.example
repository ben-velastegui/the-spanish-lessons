# Spanish Lessons App Environment Configuration
# Copy this file to .env and fill in your actual values

# GitHub Repository Configuration
GITHUB_USERNAME=ben-velastegui
GITHUB_REPO=the-spanish-lessons
GITHUB_BRANCH=main

# App Distribution URLs
BASE_URL=https://ben-velastegui.github.io/the-spanish-lessons
IOS_MANIFEST_URL=https://ben-velastegui.github.io/the-spanish-lessons/ios/manifest.plist
ANDROID_APK_URL=https://ben-velastegui.github.io/the-spanish-lessons/android/SpanishLessons-v1.0.0.apk
IOS_IPA_URL=https://ben-velastegui.github.io/the-spanish-lessons/ios/SpanishLessons-v1.0.0.ipa

# Contact Information (for app)
CONTACT_EMAIL=info@thespanishlessons.com
CONTACT_PHONE=+447912345678
WEBSITE_URL=https://thespanishlessons.github.io

# App Configuration
APP_NAME=Spanish Lessons
APP_VERSION=1.0.0
BUNDLE_ID=com.thespanishlessons.app

# Analytics (optional)
GOOGLE_ANALYTICS_ID=
SENTRY_DSN=

# Development Settings
NODE_ENV=production
EXPO_PUBLIC_APP_ENV=production
